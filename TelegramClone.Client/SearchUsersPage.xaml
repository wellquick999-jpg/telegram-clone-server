<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TelegramClone.Client.SearchUsersPage"
             Title="Поиск пользователей"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1a1a1a}">
    
    <VerticalStackLayout Spacing="10" Padding="10">
        
        <Entry x:Name="SearchEntry"
               Placeholder="Введите номер телефона или @username"
               ReturnType="Search"
               Completed="OnSearchCompleted"
               BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2a2a2a}"
               TextColor="{AppThemeBinding Light=Black, Dark=White}"
               PlaceholderColor="{AppThemeBinding Light=Gray, Dark=#8a8a8a}"/>
        
        <CollectionView x:Name="UsersCollection"
                        SelectionMode="Single"
                        SelectionChanged="OnUserSelected"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1a1a1a}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" 
                          ColumnDefinitions="Auto,*,Auto"
                          BackgroundColor="{AppThemeBinding Light=White, Dark=#1a1a1a}">
                        
                        <Frame Grid.Column="0" 
                               WidthRequest="50" 
                               HeightRequest="50"
                               CornerRadius="25"
                               BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#2a2a2a}">
                            <Label Text="{Binding Username[0]}" 
                                   FontSize="24"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                        </Frame>
                        
                        <VerticalStackLayout Grid.Column="1" Spacing="3" Margin="10,0">
                            <Label Text="{Binding Username}" 
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                            <Label Text="@{Binding UserTag}" 
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                        </VerticalStackLayout>
                        
                        <Label Grid.Column="2" 
                               Text="Выбрать"
                               TextColor="#2A6B9F"
                               FontSize="14"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <Label x:Name="StatusLabel" 
               Text=""
               HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=Red, Dark=#ff6666}"/>
        
    </VerticalStackLayout>
</ContentPage>